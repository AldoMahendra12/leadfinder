# Google Sheets Setup (opsional, hanya kalau mau export leads ke Sheets)
GOOGLE_SERVICE_ACCOUNT_EMAIL="your-service-account-email@project.iam.gserviceaccount.com"
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour...\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEET_ID="your-google-sheet-id"

# External APIs (wajib)
SERPER_API_KEY="your-serper-api-key"
OPENROUTER_API_KEY="your-openrouter-api-key"
# OpenRouter model — free tier, fast, reliable. Swap for "openai/gpt-4o-mini" if you want paid.
OPENROUTER_MODEL="meta-llama/llama-3.1-8b-instruct:free"

# Email Verification — AbstractAPI (optional but recommended)
# Free tier: 100 verifications/month — https://www.abstractapi.com/email-verification-api
# If left empty, pattern guessing still runs but skips verification (lower accuracy)
ABSTRACT_API_KEY=""

# Pre-Call Audit System
# Google PageSpeed Insights -- no key needed for basic usage (25 req/100s free)
# If you hit rate limits, get a free key at: https://developers.google.com/speed/docs/insights/v5/get-started
PAGESPEED_API_KEY=""
